{
  "expo": {
    "name": "law-articles-app",
    "slug": "law-articles-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071a34"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ph.edu.tip.constitutionTIPproject",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ph.edu.tip.constitutionreader",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071a34"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6488ca1a-474f-4398-9ca6-3e6a738ac3bf"
      }
    }
  }
}
